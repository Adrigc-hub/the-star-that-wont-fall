<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Frostbound: Cosmic Eclipse (750+ Lines Edition)</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            -webkit-user-select: none;
        }
        body {
            background-color: #020306;
            color: #ffffff;
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }
        #gameContainer {
            position: relative;
            width: 100vw;
            max-width: 640px;
            height: 100vh;
            max-height: 480px;
            border: 4px solid #c93d14;
            box-shadow: 0 0 35px rgba(201, 61, 20, 0.4);
            background-color: #000;
        }
        canvas {
            display: block;
            width: 100%;
            height: 100%;
            image-rendering: pixelated;
        }
        #instructions {
            margin-top: 10px;
            font-size: 12px;
            color: #ff9d7d;
            text-align: center;
            max-width: 600px;
            line-height: 1.4;
        }
        #audioPrompt {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(3, 4, 8, 0.98);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            text-align: center;
            padding: 20px;
        }
        button {
            background: #fcae1e;
            border: none;
            color: #000;
            padding: 15px 40px;
            font-size: 18px;
            font-family: inherit;
            font-weight: bold;
            cursor: pointer;
            margin-top: 25px;
            border-radius: 4px;
            box-shadow: 0 6px #c93d14;
            transition: all 0.1s ease;
        }
        button:active {
            transform: translateY(4px);
            box-shadow: 0 2px #c93d14;
        }
        .warning-tag {
            color: #ff3e3e;
            font-weight: bold;
            border: 1px solid #ff3e3e;
            padding: 3px 8px;
            margin-top: 15px;
            font-size: 11px;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div id="gameContainer">
        <div id="audioPrompt">
            <h2 style="color: #fcae1e; letter-spacing: 3px; font-size: 24px;">COSMIC ECLIPSE</h2>
            <p style="margin-top: 12px; font-size: 13px; max-width: 480px; color: #cbd5e1; line-height: 1.5;">
                ¡Doble Motor de Undertale activado! Explora 4 habitaciones gigantescas con 220 NPCs y enfrenta a la mítica estrella rebelde en: <br>
                <span style="color: #fff; font-weight: bold;">"The Star That Doesn't Want To Fall"</span>
            </p>
            <div class="warning-tag">ADVERTENCIA: CONTIENE AUDIO CHIPTUNE EN TIEMPO REAL</div>
            <button onclick="initializeEngine()">¡INICIAR COMBATE X2!</button>
        </div>
        <canvas id="gameCanvas" width="640" height="480"></canvas>
    </div>
    
    <div id="instructions">
        <strong>Moverse:</strong> Flechas de dirección / Arrastrar pantalla.<br>
        <strong>Z / Enter / Pulsar diálogos:</strong> Interactuar. ¡Traspasa los límites del mapa para cambiar de habitación!
    </div>

    <script>
        // ==========================================
        // 1. CONFIGURACIÓN Y VARIABLES GLOBALES
        // ==========================================
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");

        let gameState = "loading"; // "loading", "overworld", "transition", "boss_intro", "battle_phase1", "battle_phase2", "victory"
        let loadProgress = 0;
        let transitionTimer = 0;
        let currentRoom = 0; // 0: Bosque, 1: Pueblo, 2: Cavernas, 3: Altar Estelar
        let shakeAmount = 0;
        let globalTimer = 0;

        // Estadísticas del jugador
        const player = {
            x: 120,
            y: 240,
            size: 20,
            speed: 5.5,
            hp: 99,
            maxHp: 99,
            isMoving: false,
            isDragging: false,
            targetX: null,
            targetY: null,
            invulFrames: 0
        };

        // Estructuras de partículas y proyectiles
        let particles = [];
        let projectiles = [];
        let screenFlashing = 0;

        // ==========================================
        // 2. MOTOR DE SÍNTESIS DE AUDIO CHIPTUNE (POLIFÓNICO)
        // ==========================================
        let audioCtx = null;
        let currentSeqInterval = null;
        let currentTrack = "";
        let musicBpm = 100;
        let seqStep = 0;

        // Escalas musicales para "Twinkle Twinkle Little Star"
        const notesFreq = {
            'C4': 261.63, 'D4': 293.66, 'E4': 329.63, 'F4': 349.23, 'G4': 392.00, 'A4': 440.00, 'B4': 493.88,
            'C5': 523.25, 'D5': 587.33, 'E5': 659.25, 'F5': 698.46, 'G5': 783.99, 'A5': 880.00, 'B5': 987.77,
            'C3': 130.81, 'G3': 196.00, 'A3': 220.00, 'F3': 174.61, 'E3': 164.81, 'D3': 146.83
        };

        // Estructura de la melodía clásica deformada
        const melodyMelancholy = [
            'C4', 'C4', 'G4', 'G4', 'A4', 'A4', 'G4', 'G4',
            'F4', 'F4', 'E4', 'E4', 'D4', 'D4', 'C4', 'C4',
            'G4', 'G4', 'F4', 'F4', 'E4', 'E4', 'D4', 'D4',
            'G4', 'G4', 'F4', 'F4', 'E4', 'E4', 'D4', 'D4'
        ];

        const bassMelancholy = [
            'C3', 'C3', 'E3', 'E3', 'F3', 'F3', 'C3', 'C3',
            'F3', 'F3', 'C3', 'C3', 'G3', 'G3', 'C3', 'C3',
            'E3', 'E3', 'D3', 'D3', 'C3', 'C3', 'G3', 'G3',
            'E3', 'E3', 'D3', 'D3', 'C3', 'C3', 'G3', 'G3'
        ];

        function initializeEngine() {
            document.getElementById("audioPrompt").style.display = "none";
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            playTrack("loading_theme");
        }

        function createSynthVoice(freq, type, duration, volume, slideTo = 0) {
            if (!audioCtx) return;
            try {
                let osc = audioCtx.createOscillator();
                let gainNode = audioCtx.createGain();
                osc.connect(gainNode);
                gainNode.connect(audioCtx.destination);

                osc.type = type;
                osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
                if (slideTo > 0) {
                    osc.frequency.exponentialRampToValueAtTime(slideTo, audioCtx.currentTime + duration);
                }

                gainNode.gain.setValueAtTime(volume, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);

                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch (e) {
                console.warn("Audio Context Glitch:", e);
            }
        }

        function playNoiseDrum(duration, volume) {
            if (!audioCtx) return;
            try {
                let bufferSize = audioCtx.sampleRate * duration;
                let buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
                let data = buffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) {
                    data[i] = Math.random() * 2 - 1;
                }

                let noise = audioCtx.createBufferSource();
                noise.buffer = buffer;

                let filter = audioCtx.createBiquadFilter();
                filter.type = 'bandpass';
                filter.frequency.value = 1000;

                let gain = audioCtx.createGain();
                gain.gain.setValueAtTime(volume, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);

                noise.connect(filter);
                filter.connect(gain);
                gain.connect(audioCtx.destination);

                noise.start();
            } catch (e) {}
        }

        function playTrack(track) {
            if (currentTrack === track) return;
            currentTrack = track;
            if (currentSeqInterval) clearInterval(currentSeqInterval);

            seqStep = 0;
            if (track === "loading_theme") {
                musicBpm = 110;
                currentSeqInterval = setInterval(() => {
                    let note = melodyMelancholy[seqStep % melodyMelancholy.length];
                    createSynthVoice(notesFreq[note] / 2, "sine", 0.4, 0.15);
                    seqStep++;
                }, 60000 / musicBpm);
            } 
            else if (track === "overworld_theme") {
                musicBpm = 100;
                currentSeqInterval = setInterval(() => {
                    let note = melodyMelancholy[seqStep % melodyMelancholy.length];
                    let bassNote = bassMelancholy[seqStep % bassMelancholy.length];
                    
                    // Melodía suave en triángulo
                    createSynthVoice(notesFreq[note], "triangle", 0.35, 0.12);
                    // Acompañamiento armónico en seno
                    if (seqStep % 2 === 0) {
                        createSynthVoice(notesFreq[bassNote], "sine", 0.7, 0.08);
                    }
                    seqStep++;
                }, 60000 / musicBpm);
            } 
            else if (track === "boss_phase1") {
                // "The Star That Doesn't Want to Fall" - Fase 1 (Solemne, épico, chiptune lento)
                musicBpm = 95;
                currentSeqInterval = setInterval(() => {
                    let note = melodyMelancholy[seqStep % melodyMelancholy.length];
                    let bassNote = bassMelancholy[seqStep % bassMelancholy.length];
                    
                    // Melodía con vibrato/eco
                    createSynthVoice(notesFreq[note], "triangle", 0.5, 0.14);
                    createSynthVoice(notesFreq[note] * 2, "sine", 0.25, 0.04); // Armónico alto
                    
                    // Bajo de soporte
                    createSynthVoice(notesFreq[bassNote] / 2, "sawtooth", 0.5, 0.09);

                    // Pequeño bombo sintetizado en cada pulso
                    if (seqStep % 4 === 0) {
                        createSynthVoice(110, "sine", 0.2, 0.25, 40);
                    }
                    seqStep++;
                }, 60000 / musicBpm);
            } 
            else if (track === "boss_phase2") {
                // "The Star That Doesn't Want to Fall" - Fase 2 (¡FRENÉTICO, BRUTAL!)
                musicBpm = 160;
                currentSeqInterval = setInterval(() => {
                    let noteIndex = seqStep % melodyMelancholy.length;
                    let note = melodyMelancholy[noteIndex];
                    let bassNote = bassMelancholy[noteIndex];
                    
                    // Pluck principal de sierra super agresivo
                    createSynthVoice(notesFreq[note], "sawtooth", 0.15, 0.15);
                    
                    // Arpegio super rápido simulando "Starfall"
                    let arpNotes = ['C5', 'E5', 'G5', 'C6'];
                    let arpNote = arpNotes[seqStep % arpNotes.length];
                    createSynthVoice(notesFreq[arpNote], "square", 0.08, 0.05);

                    // Sub-bajo aplastante
                    createSynthVoice(notesFreq[bassNote] / 2, "triangle", 0.2, 0.2);

                    // Batería Chiptune integrada
                    if (seqStep % 4 === 0) {
                        // Bombo rudo
                        createSynthVoice(160, "sine", 0.12, 0.4, 30);
                    } else if (seqStep % 4 === 2) {
                        // Caja de ruido blanco (Snare)
                        playNoiseDrum(0.12, 0.35);
                    } else if (seqStep % 2 === 1) {
                        // Platillos rápidos (Hi-hat)
                        playNoiseDrum(0.02, 0.12);
                    }

                    seqStep++;
                }, 60000 / musicBpm);
            }
        }

        function playSfx(type) {
            if (!audioCtx) return;
            try {
                if (type === "talk") {
                    createSynthVoice(180 + Math.random() * 90, "sine", 0.05, 0.15);
                } else if (type === "hit") {
                    createSynthVoice(120, "sawtooth", 0.2, 0.4, 20);
                } else if (type === "phase_shift") {
                    createSynthVoice(50, "sawtooth", 1.8, 0.5, 900);
                } else if (type === "star_shoot") {
                    createSynthVoice(600, "square", 0.1, 0.08, 100);
                }
            } catch (e) {}
        }


        // ==========================================
        // 3. GENERADOR INTEGRADO DE 220 NPCs
        // ==========================================
        const npcs = [];
        const npcNames = ["Aero", "Bliz", "Cenit", "Drift", "Ember", "Flurry", "Gale", "Haze", "Ion", "Jolt", "Kael", "Lumi", "Melt", "Nova", "Opal", "Pyre", "Quasar", "Rime", "Silt", "Tundra", "Vapor", "Wisp", "Zephyr"];
        const npcDialogues = [
            "* ¡El cosmos se distorsiona de forma masiva! Siento que somos el doble de almas.",
            "* La leyenda cuenta que las estrellas caídas son las más dóciles. Pero hay una que no quiere caer.",
            "* Un zorro de corazón puro y un Protogen Carmesí resguardan el orden cósmico.",
            "* Si te acercas al Altar de la Habitación 3, te sugiero estar listo para la batalla.",
            "* Ten cuidado con los destellos de color carmesí... anuncian el colapso del firmamento."
        ];

        // Distribución optimizada de 220 NPCs en las 4 habitaciones (55 NPCs por sala)
        for (let i = 0; i < 220; i++) {
            const assignedRoom = Math.floor(i / 55);
            // Colocar NPCs esparcidos uniformemente en cuadrículas sin obstruir el centro
            const gridCol = i % 8;
            const gridRow = Math.floor((i % 55) / 8);
            npcs.push({
                id: i,
                room: assignedRoom,
                x: 60 + (gridCol * 70) + (Math.sin(i) * 15),
                y: 80 + (gridRow * 50) + (Math.cos(i) * 10),
                size: 14,
                color: `hsl(${(i * 17) % 360}, 85%, 75%)`,
                name: `${npcNames[i % npcNames.length]} #${i + 1}`,
                dialogue: [
                    `* Hablas con ${npcNames[i % npcNames.length]} #${i + 1}.`,
                    npcDialogues[i % npcDialogues.length],
                    `* Parece estar temblando de frío pero resiste con determinación.`
                ],
                currentLine: -1
            });
        }


        // ==========================================
        // 4. ENTIDAD DEL JEFE: "THE STAR THAT DOESN'T WANT TO FALL"
        // ==========================================
        const starBoss = {
            x: 320,
            y: 130,
            size: 45,
            health: 200,
            maxHealth: 200,
            phase: 1, // 1: Standard, 2: Brutal Desperation
            angryState: 0, // Animación de furia
            dialogue: [
                "* He observado el firmamento durante millones de años...",
                "* Los dioses cósmicos ordenan mi descenso.",
                "* Quieren que caiga, que me apague, que muera como el resto.",
                "* ¡PERO YO NO QUIERO CAER!",
                "* Si debo colapsar, me llevaré este universo digital conmigo."
            ],
            currentLine: -1
        };


        // ==========================================
        // 5. pixel art matrices (KIBA, PROTOGEN Y STAR JEFE)
        // ==========================================
        const spriteKiba = [
            ".....WW.....WW.....",
            "....WWBW...BWWB....",
            "....WWWWWWWWWWW....",
            "....WWWCCWWWCCW....",
            ".....WWWWWWWWW.....",
            ".......WWBWW.......",
            ".......BBBBB.......",
            ".....BWWWWWWWB.....",
            "....BBWWWWWWWB.....",
            "......WW...WW......",
            "......BB...BB......"
        ];
        const colorsKiba = { "W": "#ffffff", "B": "#1d3363", "C": "#00d2ff" };

        const spriteProtogen = [
            "....O................................O....",
            "...OOO..............................OOO...",
            "...O.O..............................O.O...",
            "...O.Y.O..........................O.Y.O...",
            "....OYYO..........................OYYO....",
            ".....OYYOOOOOOOOOOOOOOOOOOOOOOOOOOYYO.....",
            ".....OYYYGGGGGGGGGGGGGGGGGGGGGGGGYYYO.....",
            "......OYGGGGGGGGGGGGGGGGGGGGGGGGGYO.......",
            "......OGGDDDDDDDDDDDDDDDDDDDDDDDDG........",
            ".....OGGDDDDDDDDDDDDDDDDDDDDDDDDDDG.......",
            "....OOGGDDDDYYYYYDDDDDDDDYYYYYDDDDGG......",
            "...OOOGGDDDDYYYYYDDDDDDDDYYYYYDDDDGGO.....",
            "..OOOOOGDDDDYYYYYDDDDDDDDYYYYYDDDDGOOO....",
            "..OOOOOGDDDDDDDDDDDDDDDDDDDDDDDDDDGOOO....",
            "..OOOOOGDDDDYDDDDDDDDDDDDDDDDYDDDDGOOO....",
            "...OOOOGDDDDYYYYYYYYYYYYYYYYYYDDDDGOOO....",
            "....OOOOGDDDDYYYYYYYYYYYYYYYYDDDDGOOO.....",
            "......OOOGGDDDDDDDDDDDDDDDDDDGGOO.......",
            "........OOOGGGGGGGGGGGGGGGGGG.........."
        ];
        const colorsProtogen = { 
            "O": "#c93d14", "Y": "#fcae1e", "D": "#111424", "G": "#7e879c"
        };

        // Diseño exclusivo para "The Star That Doesn't Want to Fall"
        const spriteStarBoss1 = [
            "......Y......",
            ".....YYY.....",
            "....YYYYY....",
            "WWYYYYYYYYYWW",
            ".WYYYYYYYYYW.",
            "..YYYYYYYYY..",
            "...YYYYYYY...",
            "....YYYYY....",
            "....YYYYY....",
            "...YY...YY...",
            "..YY.....YY.."
        ];
        const colorsStar1 = { "Y": "#ffd700", "W": "#ffffff" };

        const spriteStarBoss2 = [
            "......R......",
            ".....RRR.....",
            "....RDRDR....",
            "BBRRRDRRRRRGB",
            ".BRRDRDRRRGB.",
            "..RRRRDRRRR..",
            "...RRDDRRR...",
            "....RDRDR....",
            "....RDRDR....",
            "...RR...RR...",
            "..RR.....RR.."
        ];
        const colorsStar2 = { "R": "#ff3b30", "D": "#110000", "B": "#ffffff", "G": "#ff8e2b" };


        function drawPixelSprite(x, y, scale, matrix, colors) {
            ctx.save();
            ctx.translate(x, y);
            ctx.scale(scale, scale);
            const rLen = matrix.length;
            const cLen = matrix[0].length;
            for (let r = 0; r < rLen; r++) {
                for (let c = 0; c < cLen; c++) {
                    const char = matrix[r][c];
                    if (char !== "." && colors[char]) {
                        ctx.fillStyle = colors[char];
                        ctx.fillRect(c - cLen / 2, r - rLen / 2, 1, 1);
                    }
                }
            }
            ctx.restore();
        }

        // ==========================================
        // 6. CONTROLADORES DE EVENTO Y DRAG TOUCH
        // ==========================================
        const keys = {};
        window.addEventListener("keydown", (e) => { 
            keys[e.code] = true; 
            if (e.code === "KeyZ" || e.code === "Enter") {
                handleInteraction();
            }
        });
        window.addEventListener("keyup", (e) => { keys[e.code] = false; });

        canvas.addEventListener("touchstart", (e) => {
            if (gameState === "loading") return;
            const rect = canvas.getBoundingClientRect();
            const touchX = ((e.touches[0].clientX - rect.left) / rect.width) * canvas.width;
            const touchY = ((e.touches[0].clientY - rect.top) / rect.height) * canvas.height;
            
            if (currentActiveDialogueNpc !== null) {
                advanceDialogue();
                return;
            }

            player.isDragging = true;
            player.targetX = touchX;
            player.targetY = touchY;
        });

        canvas.addEventListener("touchmove", (e) => {
            if (player.isDragging) {
                const rect = canvas.getBoundingClientRect();
                player.targetX = ((e.touches[0].clientX - rect.left) / rect.width) * canvas.width;
                player.targetY = ((e.touches[0].clientY - rect.top) / rect.height) * canvas.height;
            }
            e.preventDefault();
        }, { passive: false });

        canvas.addEventListener("touchend", () => {
            player.isDragging = false;
            player.targetX = null;
            player.targetY = null;
        });

        let currentActiveDialogueNpc = null;

        function handleInteraction() {
            if (currentActiveDialogueNpc !== null) {
                advanceDialogue();
                return;
            }

            // Interactuar con NPCs en la habitación activa
            const activeNpcs = npcs.filter(n => n.room === currentRoom);
            for (let npc of activeNpcs) {
                if (Math.hypot(player.x - npc.x, player.y - npc.y) < 32) {
                    currentActiveDialogueNpc = npc;
                    npc.currentLine = 0;
                    playSfx("talk");
                    return;
                }
            }

            // En la Habitación 3, interactuar con el altar de la estrella
            if (currentRoom === 3 && gameState === "overworld" && Math.hypot(player.x - starBoss.x, player.y - starBoss.y) < 55) {
                currentActiveDialogueNpc = starBoss;
                starBoss.currentLine = 0;
                playSfx("talk");
            }
        }

        function advanceDialogue() {
            currentActiveDialogueNpc.currentLine++;
            if (currentActiveDialogueNpc.currentLine >= currentActiveDialogueNpc.dialogue.length) {
                if (currentActiveDialogueNpc === starBoss) {
                    gameState = "boss_intro";
                    transitionTimer = 0;
                }
                currentActiveDialogueNpc = null;
            } else {
                playSfx("talk");
            }
        }


        // ==========================================
        // 7. SISTEMA DE COLISIONES Y TRANSICIONES DE MAPA
        // ==========================================
        function updateRoomTransitions() {
            // Mapa 2x2:
            // [Room 2: Cavernas] <---> [Room 3: Altar Estelar]
            //         ^                      ^
            //         v                      v
            // [Room 0: Bosque  ] <---> [Room 1: Pueblo]

            if (player.x < 10) {
                if (currentRoom === 1) { currentRoom = 0; player.x = 610; }
                else if (currentRoom === 3) { currentRoom = 2; player.x = 610; }
                else { player.x = 10; }
                playSfx("talk");
                spawnRoomParticles();
            }
            else if (player.x > 630) {
                if (currentRoom === 0) { currentRoom = 1; player.x = 30; }
                else if (currentRoom === 2) { currentRoom = 3; player.x = 30; }
                else { player.x = 630; }
                playSfx("talk");
                spawnRoomParticles();
            }

            if (player.y < 10) {
                if (currentRoom === 0) { currentRoom = 2; player.y = 450; }
                else if (currentRoom === 1) { currentRoom = 3; player.y = 450; }
                else { player.y = 10; }
                playSfx("talk");
                spawnRoomParticles();
            }
            else if (player.y > 470) {
                if (currentRoom === 2) { currentRoom = 0; player.y = 30; }
                else if (currentRoom === 3) { currentRoom = 1; player.y = 30; }
                else { player.y = 470; }
                playSfx("talk");
                spawnRoomParticles();
            }
        }

        function spawnRoomParticles() {
            particles = [];
            for (let i = 0; i < 30; i++) {
                particles.push({
                    x: Math.random() * 640,
                    y: Math.random() * 480,
                    size: Math.random() * 3 + 1,
                    speedY: -Math.random() * 1.5,
                    alpha: Math.random()
                });
            }
        }


        // ==========================================
        // 8. BUCLE DE ACTUALIZACIÓN (MAIN UPDATE & DRAW)
        // ==========================================
        const battleBox = { x: 170, y: 220, width: 300, height: 180 };

        function updateGame() {
            globalTimer++;
            if (shakeAmount > 0) shakeAmount -= 0.15;
            if (screenFlashing > 0) screenFlashing -= 0.05;

            // Manejo de frames de invulnerabilidad
            if (player.invulFrames > 0) player.invulFrames--;

            if (gameState === "loading") {
                if (loadProgress < 100) {
                    loadProgress += 0.5;
                } else {
                    gameState = "overworld";
                    playTrack("overworld_theme");
                    spawnRoomParticles();
                }
            } 
            else if (gameState === "overworld") {
                updatePlayerMovement();
                updateRoomTransitions();
                
                // Actualizar partículas estéticas ambientales
                particles.forEach(p => {
                    p.y += p.speedY;
                    if (p.y < 0) { p.y = 480; p.x = Math.random() * 640; }
                });
            } 
            else if (gameState === "boss_intro") {
                transitionTimer++;
                shakeAmount = 2.5;
                if (transitionTimer > 100) {
                    gameState = "battle_phase1";
                    playTrack("boss_phase1");
                    player.x = 320;
                    player.y = 310;
                    projectiles = [];
                    transitionTimer = 0;
                }
            } 
            else if (gameState === "battle_phase1" || gameState === "battle_phase2") {
                updatePlayerMovementInBattle();
                updateProjectiles();
                
                // Regeneración de ataques automáticos
                let maxProj = gameState === "battle_phase2" ? 8 : 4;
                if (projectiles.length < maxProj && Math.random() < 0.04) {
                    fireBossAttack();
                }

                // Si la estrella de la Fase 1 baja de vida, muta de fase
                if (starBoss.health <= 100 && starBoss.phase === 1) {
                    starBoss.phase = 2;
                    gameState = "transition";
                    transitionTimer = 0;
                    projectiles = [];
                    playSfx("phase_shift");
                }

                // Condición de victoria
                if (starBoss.health <= 0) {
                    gameState = "victory";
                    playTrack("overworld_theme");
                }
            }
            else if (gameState === "transition") {
                transitionTimer++;
                shakeAmount = 4;
                screenFlashing = 0.4;
                if (transitionTimer > 130) {
                    gameState = "battle_phase2";
                    playTrack("boss_phase2");
                    player.x = 320;
                    player.y = 310;
                }
            }
        }

        function updatePlayerMovement() {
            if (currentActiveDialogueNpc !== null) {
                player.isMoving = false;
                return;
            }
            player.isMoving = false;

            if (player.isDragging && player.targetX !== null) {
                const dx = player.targetX - player.x;
                const dy = player.targetY - player.y;
                const dist = Math.hypot(dx, dy);
                if (dist > 6) {
                    player.x += (dx / dist) * player.speed;
                    player.y += (dy / dist) * player.speed;
                    player.isMoving = true;
                }
            } else {
                if (keys["ArrowUp"]) { player.y -= player.speed; player.isMoving = true; }
                if (keys["ArrowDown"]) { player.y += player.speed; player.isMoving = true; }
                if (keys["ArrowLeft"]) { player.x -= player.speed; player.isMoving = true; }
                if (keys["ArrowRight"]) { player.x += player.speed; player.isMoving = true; }
            }
        }

        function updatePlayerMovementInBattle() {
            if (player.isDragging && player.targetX !== null) {
                const dx = player.targetX - player.x;
                const dy = player.targetY - player.y;
                const dist = Math.hypot(dx, dy);
                if (dist > 4) {
                    player.x += (dx / dist) * 4.2;
                    player.y += (dy / dist) * 4.2;
                }
            } else {
                if (keys["ArrowUp"]) player.y -= 4.2;
                if (keys["ArrowDown"]) player.y += 4.2;
                if (keys["ArrowLeft"]) player.x -= 4.2;
                if (keys["ArrowRight"]) player.x += 4.2;
            }

            // Mantener al jugador atrapado en la Battle Box de Undertale
            const minX = battleBox.x + player.size/2 + 2;
            const maxX = battleBox.x + battleBox.width - player.size/2 - 2;
            const minY = battleBox.y + player.size/2 + 2;
            const maxY = battleBox.y + battleBox.height - player.size/2 - 2;

            player.x = Math.max(minX, Math.min(maxX, player.x));
            player.y = Math.max(minY, Math.min(maxY, player.y));
        }


        // ==========================================
        // 9. PATRONES DE PROYECTILES DEL BOSS "THE STAR THAT DOESNT WANT TO FALL"
        // ==========================================
        function fireBossAttack() {
            playSfx("star_shoot");
            if (gameState === "battle_phase1") {
                // Patrón 1: Estrellas espirales
                let randAngle = Math.random() * Math.PI * 2;
                projectiles.push({
                    type: "star",
                    x: starBoss.x,
                    y: starBoss.y,
                    vx: Math.cos(randAngle) * 3,
                    vy: Math.sin(randAngle) * 3 + 1,
                    size: 14,
                    color: "#fffb00"
                });
            } else {
                // Fase 2: Lluvia vertical frenética + proyectiles rebotantes (¡80 patrones de color!)
                let modes = ["rain", "spiral_frenzy", "cross_shoot"];
                let chosen = modes[Math.floor(Math.random() * modes.length)];

                if (chosen === "rain") {
                    projectiles.push({
                        type: "rain",
                        x: battleBox.x + Math.random() * battleBox.width,
                        y: battleBox.y - 10,
                        vx: (Math.random() - 0.5) * 2,
                        vy: 4.5 + Math.random() * 3,
                        size: 12,
                        color: "#ff3b30"
                    });
                } else if (chosen === "spiral_frenzy") {
                    let steps = 6;
                    for (let i = 0; i < steps; i++) {
                        let angle = (globalTimer * 0.15) + (i * (Math.PI * 2 / steps));
                        projectiles.push({
                            type: "star",
                            x: starBoss.x,
                            y: starBoss.y,
                            vx: Math.cos(angle) * 4.5,
                            vy: Math.sin(angle) * 4.5,
                            size: 13,
                            color: `hsl(${(globalTimer * 4) % 360}, 90%, 65%)`
                        });
                    }
                } else {
                    // Disparo directo de advertencia
                    let angleToPlayer = Math.atan2(player.y - starBoss.y, player.x - starBoss.x);
                    projectiles.push({
                        type: "homing",
                        x: starBoss.x,
                        y: starBoss.y,
                        vx: Math.cos(angleToPlayer) * 5.5,
                        vy: Math.sin(angleToPlayer) * 5.5,
                        size: 16,
                        color: "#ffa500"
                    });
                }
            }
        }

        function updateProjectiles() {
            for (let i = projectiles.length - 1; i >= 0; i--) {
                let p = projectiles[i];
                p.x += p.vx;
                p.y += p.vy;

                // Colisión directa con el Corazón / Alma de Kiba
                let dist = Math.hypot(player.x - p.x, player.y - p.y);
                if (dist < (player.size/2 + p.size/2 - 2)) {
                    if (player.invulFrames === 0) {
                        player.hp -= gameState === "battle_phase2" ? 18 : 10;
                        player.invulFrames = 45; // Frames de invencibilidad
                        shakeAmount = 4;
                        playSfx("hit");
                        
                        // Infligir daño de vuelta a la estrella indomable cuando chocas
                        starBoss.health -= 15;
                    }
                }

                // El jugador también puede atacar pulsando las teclas de dirección/Z para restarle vida al boss
                if (globalTimer % 20 === 0) {
                    starBoss.health -= 1; // El tiempo y esquivar daña gradualmente al boss
                }

                // Eliminar proyectiles fuera de los márgenes del juego
                if (p.y > 480 || p.x < 0 || p.x > 640 || p.y < 0) {
                    projectiles.splice(i, 1);
                }
            }
        }


        // ==========================================
        // 10. ARQUITECTURA DE RENDERIZADO GRÁFICO (WEB GLOW CANVAS)
        // ==========================================
        function drawGame() {
            ctx.save();
            // Implementación del sacudidor de pantalla (Screen Shake)
            if (shakeAmount > 0) {
                let dx = (Math.random() - 0.5) * shakeAmount;
                let dy = (Math.random() - 0.5) * shakeAmount;
                ctx.translate(dx, dy);
            }

            // Renderizar fondos atmosféricos de las salas
            if (gameState === "loading") {
                drawLoadingScreen();
            } else if (gameState === "overworld") {
                drawOverworldMap();
            } else if (gameState === "boss_intro") {
                drawBossIntro();
            } else if (gameState === "battle_phase1" || gameState === "battle_phase2") {
                drawBattleScene();
            } else if (gameState === "transition") {
                drawPhaseTransition();
            } else if (gameState === "victory") {
                drawVictoryScreen();
            }

            // Superposición de Flash de Pantalla
            if (screenFlashing > 0) {
                ctx.fillStyle = `rgba(255, 62, 20, ${screenFlashing})`;
                ctx.fillRect(0, 0, canvas.width, canvas.height);
            }

            ctx.restore();
        }

        function drawLoadingScreen() {
            ctx.fillStyle = "#04050a";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Rostro gigante del Protogen de la foto para recibir al jugador
            drawPixelSprite(320, 170, 6, spriteProtogen, colorsProtogen);

            ctx.fillStyle = "#ffffff";
            ctx.font = "14px 'Courier New'";
            ctx.textAlign = "center";
            ctx.fillText("CRUZANDO DIMENSIONES DE CRISTAL...", 320, 310);
            ctx.fillText("SINTETIZANDO 220 ALMAS INDOMABLES...", 320, 335);

            // Barra de carga estilo Retro
            ctx.strokeStyle = "#c93d14";
            ctx.lineWidth = 3;
            ctx.strokeRect(170, 370, 300, 20);

            ctx.fillStyle = "#fcae1e";
            ctx.fillRect(174, 374, (292 * loadProgress) / 100, 12);
        }

        function drawOverworldMap() {
            // Fondos exclusivos según la habitación
            const backgroundColors = ["#070a12", "#0a1410", "#100914", "#180c0a"];
            ctx.fillStyle = backgroundColors[currentRoom];
            ctx.fillRect(0, 0, 640, 480);

            // Detalles estéticos en el piso (Estilo Undertale Tiles)
            ctx.fillStyle = "rgba(255, 255, 255, 0.04)";
            for (let i = 0; i < 8; i++) {
                ctx.fillRect(40 + i * 80, 100, 40, 10);
                ctx.fillRect(80 + i * 80, 300, 40, 10);
            }

            // Renderizar partículas cósmicas flotantes
            ctx.fillStyle = "rgba(255, 255, 255, 0.4)";
            particles.forEach(p => {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();
            });

            // Dibujar solo los NPCs que pertenecen a la habitación actual
            const activeNpcs = npcs.filter(n => n.room === currentRoom);
            activeNpcs.forEach(npc => {
                ctx.save();
                ctx.translate(npc.x, npc.y + Math.sin(globalTimer * 0.05 + npc.id) * 3);
                ctx.fillStyle = npc.color;
                ctx.fillRect(-7, -7, 14, 14);
                // Ojos
                ctx.fillStyle = "#000000";
                ctx.fillRect(-3, -4, 2, 3);
                ctx.fillRect(1, -4, 2, 3);
                ctx.restore();
            });

            // En la Habitación 3, colocar la estrella como NPC esperando interacción
            if (currentRoom === 3) {
                drawPixelSprite(starBoss.x, starBoss.y, 3.2, spriteStarBoss1, colorsStar1);
                
                // Efecto de aura cósmica parpadeante
                ctx.strokeStyle = "rgba(255, 215, 0, 0.35)";
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.arc(starBoss.x, starBoss.y, 40 + Math.sin(globalTimer * 0.1) * 5, 0, Math.PI*2);
                ctx.stroke();
            }

            // Dibujar al Jugador (Kiba, el Zorrito)
            drawPixelSprite(player.x, player.y, 1.8, spriteKiba, colorsKiba);

            // Panel de estado de la habitación
            const roomsNames = ["Bosque de la Memoria", "Pueblo de los Refugiados", "Cavernas del Lamento", "Altar: La Estrella Indomable"];
            ctx.fillStyle = "rgba(0, 0, 0, 0.6)";
            ctx.fillRect(0, 0, 640, 40);
            ctx.fillStyle = "#fff";
            ctx.font = "12px 'Courier New'";
            ctx.textAlign = "left";
            ctx.fillText(`ZONA: ${roomsNames[currentRoom]} | NPCs: 220 Activos`, 15, 24);

            // Cuadro de Diálogos
            if (currentActiveDialogueNpc !== null) {
                drawDialogBox(currentActiveDialogueNpc.dialogue[currentActiveDialogueNpc.currentLine]);
            }
        }

        function drawDialogBox(text) {
            ctx.fillStyle = "#000000";
            ctx.strokeStyle = "#c93d14";
            ctx.lineWidth = 4;
            ctx.fillRect(40, 330, 560, 110);
            ctx.strokeRect(40, 330, 560, 110);

            ctx.fillStyle = "#ffffff";
            ctx.font = "13px 'Courier New'";
            ctx.textAlign = "left";
            ctx.fillText(text, 65, 370);

            ctx.fillStyle = "#ffaa00";
            ctx.font = "10px 'Courier New'";
            ctx.fillText("[Z / ENTER / TOQUE EN PANTALLA PARA AVANZAR]", 65, 415);
        }

        function drawBossIntro() {
            ctx.fillStyle = "#000000";
            ctx.fillRect(0, 0, 640, 480);

            // Acercamiento a la Estrella en tonos de advertencia
            drawPixelSprite(320, 200, 5 + Math.sin(globalTimer * 0.2) * 0.3, spriteStarBoss1, colorsStar1);

            ctx.fillStyle = "#ff3b30";
            ctx.font = "bold 16px 'Courier New'";
            ctx.textAlign = "center";
            ctx.fillText("ALERTA DE SISTEMA", 320, 330);
            ctx.fillStyle = "#ffffff";
            ctx.font = "12px 'Courier New'";
            ctx.fillText("* La estrella desafía la física del motor central.", 320, 360);
            ctx.fillText("* Su negativa a caer está colapsando el juego.", 320, 385);
        }

        function drawBattleScene() {
            ctx.fillStyle = "#020306";
            ctx.fillRect(0, 0, 640, 480);

            // Renderizado del Boss dependiendo de la fase activa
            if (gameState === "battle_phase1") {
                drawPixelSprite(320, 110 + Math.sin(globalTimer * 0.08) * 8, 3.5, spriteStarBoss1, colorsStar1);
                
                ctx.fillStyle = "#ffd700";
                ctx.font = "13px 'Courier New'";
                ctx.textAlign = "center";
                ctx.fillText('"The Star That Doesn\'t Want To Fall"', 320, 35);
            } else {
                // Fase 2: Estrella colapsada, furiosa y rota
                drawPixelSprite(320, 110 + Math.sin(globalTimer * 0.15) * 12, 3.8, spriteStarBoss2, colorsStar2);
                
                ctx.fillStyle = "#ff3b30";
                ctx.font = "bold 14px 'Courier New'";
                ctx.textAlign = "center";
                ctx.fillText("PHASE 2: THE CELESTIAL ANARCHIST", 320, 35);
            }

            // Barra de vida del Boss
            ctx.fillStyle = "#550000";
            ctx.fillRect(170, 50, 300, 14);
            ctx.fillStyle = gameState === "battle_phase1" ? "#ffd700" : "#ff3b30";
            ctx.fillRect(170, 50, (300 * starBoss.health) / starBoss.maxHealth, 14);
            ctx.strokeStyle = "#ffffff";
            ctx.lineWidth = 2;
            ctx.strokeRect(170, 50, 300, 14);

            // Dibujar la Caja de Combate de Undertale
            ctx.strokeStyle = "#ffffff";
            ctx.lineWidth = 4;
            ctx.strokeRect(battleBox.x, battleBox.y, battleBox.width, battleBox.height);

            // Renderizar proyectiles activos
            projectiles.forEach(p => {
                ctx.fillStyle = p.color;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size / 2, 0, Math.PI * 2);
                ctx.fill();
            });

            // Dibujar el Alma / Corazón del Jugador
            drawPlayerSoul(player.x, player.y);

            // Interfaz de Usuario de Combate (HUD)
            ctx.fillStyle = "#ffffff";
            ctx.font = "14px 'Courier New'";
            ctx.textAlign = "left";
            ctx.fillText(`KIBA   LV 19   HP [${player.hp}/${player.maxHp}]`, 170, 430);

            // Barra de salud del jugador en el HUD
            ctx.fillStyle = "#555";
            ctx.fillRect(170, 440, 300, 10);
            ctx.fillStyle = "#00ffcc";
            ctx.fillRect(170, 440, (300 * player.hp) / player.maxHp, 10);
        }

        function drawPlayerSoul(x, y) {
            ctx.save();
            ctx.translate(x, y);

            // Efecto de parpadeo por daño
            if (player.invulFrames % 4 > 2) {
                ctx.restore();
                return;
            }

            // Orejas de zorro representadas sobre el corazón
            ctx.fillStyle = "#00d2ff";
            ctx.fillRect(-7, -9, 3, 5);
            ctx.fillRect(4, -9, 3, 5);

            // Alma de color celeste brillante
            ctx.fillStyle = "#00e1ff";
            ctx.beginPath();
            ctx.moveTo(0, -4);
            ctx.bezierCurveTo(-5, -9, -10, -4, -10, 1);
            ctx.bezierCurveTo(-10, 6, -5, 10, 0, 14);
            ctx.bezierCurveTo(5, 10, 10, 6, 10, 1);
            ctx.bezierCurveTo(10, -4, 5, -9, 0, -4);
            ctx.fill();

            ctx.restore();
        }

        function drawPhaseTransition() {
            ctx.fillStyle = "#000000";
            ctx.fillRect(0, 0, 640, 480);

            // La estrella se rompe con efectos de temblor masivos
            drawPixelSprite(320 + (Math.random() - 0.5) * 8, 200, 4, spriteStarBoss2, colorsStar2);

            ctx.fillStyle = "#ff3b30";
            ctx.font = "bold 16px 'Courier New'";
            ctx.textAlign = "center";
            ctx.fillText("SISTEMA AL LÍMITE: FASE 2 INICIADA", 320, 320);
            
            ctx.fillStyle = "#ffffff";
            ctx.font = "12px 'Courier New'";
            ctx.fillText("* La melodía se acelera brutalmente.", 320, 355);
            ctx.fillText("* ¡LA ESTRELLA NO SE VA A RENDIR!", 320, 380);
        }

        function drawVictoryScreen() {
            ctx.fillStyle = "#050a08";
            ctx.fillRect(0, 0, 640, 480);

            // Protogen y el Zorrito Kiba observando el firmamento pacífico
            drawPixelSprite(240, 200, 3, spriteProtogen, colorsProtogen);
            drawPixelSprite(400, 220, 2, spriteKiba, colorsKiba);

            ctx.fillStyle = "#00ffcc";
            ctx.font = "20px 'Courier New'";
            ctx.textAlign = "center";
            ctx.fillText("¡EL UNIVERSO X2 HA SIDO SALVADO!", 320, 80);

            ctx.fillStyle = "#ffffff";
            ctx.font = "12px 'Courier New'";
            ctx.fillText("* La estrella finalmente brilla en armonía.", 320, 330);
            ctx.fillText("* Has completado el viaje del Altar junto a tus 220 amigos.", 320, 360);
            ctx.fillText("* ¡Gracias por jugar este épico tributo doble!", 320, 385);
        }


        // ==========================================
        // 11. INICIALIZACIÓN DEL BUCLE DEL MOTOR
        // ==========================================
        function runEngine() {
            updateGame();
            drawGame();
            requestAnimationFrame(runEngine);
        }

        // Arrancar el proceso gráfico asincrónicamente
        runEngine();

    </script>
